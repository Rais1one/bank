<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <LinearLayout
                android:id="@+id/rmcks10r9e68"
                android:layout_width="61dp"
                android:layout_height="61dp"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="13dp"
                android:background="@drawable/circle"
               >
                <ImageView
                    android:id="@+id/rkexvg38vef"
                    android:layout_width="61dp"
                    android:layout_height="61dp"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitXY"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rmcks10r9e68"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_marginBottom="7dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/r0xjhqr8mdw1n"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Кэшбэк"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rnr3m9q79eo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_marginBottom="25dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/rclqtx86bqgc"
                    android:textColor="#000000"
                    android:textSize="48sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="133 ₽"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rzi8x6ftbbqq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:background="@drawable/cr10b1c029b"
                android:paddingVertical="17dp"
                android:layout_marginBottom="44dp"
                android:layout_marginHorizontal="26dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/r6y872x36ulb"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Категории"
                    />
            </LinearLayout>
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="400dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ricuh1g6aaee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:layout_marginBottom="11dp"
                        android:text="Сегодня"
                        android:textColor="#000000"
                        android:textSize="20sp" />
                    <!-- Блок Продукты (Сегодня) -->
                    <LinearLayout
                        android:id="@+id/rrf6f2p374ho"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="26dp"
                        android:layout_marginBottom="27dp"
                        android:background="@drawable/cr10bd9d9d9"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="11dp"
                            android:scaleType="fitXY"
                            android:src="@android:drawable/star_big_on" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Продукты"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+2 ₽"
                            android:textColor="#000000"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/rso2csyz1k4d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="35dp"
                        android:layout_marginBottom="14dp"
                        android:text="13 марта"
                        android:textColor="#000000"
                        android:textSize="20sp" />


                    <LinearLayout
                        android:id="@+id/r3bddd7kzcc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="26dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/cr10bd9d9d9"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="15dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="11dp"
                            android:scaleType="fitXY"
                            android:src="@android:drawable/star_big_on" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ресторан"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+127 ₽"
                            android:textColor="#000000"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- Блок Продукты (Архив) -->
                    <LinearLayout
                        android:id="@+id/re9og9z42f3q"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="26dp"
                        android:layout_marginBottom="48dp"
                        android:background="@drawable/cr10bd9d9d9"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="17dp"
                        android:paddingVertical="13dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="10dp"
                            android:scaleType="fitXY"
                            android:src="@android:drawable/star_big_on" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Продукты"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+4 ₽"
                            android:textColor="#000000"
                            android:textSize="15sp" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

        </LinearLayout>
