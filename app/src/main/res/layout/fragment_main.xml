<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fon"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/rrxrwgemjsr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/fon"
        android:paddingBottom="73dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rjlagkxhr5ih"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="#1C029B"
                android:paddingVertical="29dp"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="202dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/ry3xadifurki"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="PEPE Банк" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/r2stmndlc4ss"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:src="@drawable/pepe"
                    android:scaleType="fitXY" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/r0x6wnn4jq65"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="25dp"
                android:layout_marginHorizontal="30dp"
                android:layout_marginTop="-150dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/maintophone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:background="@drawable/button_fon"
                    android:paddingVertical="34dp"
                    android:layout_marginEnd="32dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rfsd3jzpktsl"
                        android:textColor="@color/color_text"
                        android:textSize="20sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Перевод" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/maintocash"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:background="@drawable/button_fon"
                    android:paddingVertical="36dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/r593qcdyjki"
                        android:textColor="@color/color_text"
                        android:textSize="20sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Кэшбэк" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/maintocard"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@drawable/button_fon"
                android:paddingHorizontal="3dp"
                android:paddingVertical="16dp"
                android:layout_marginBottom="251dp"
                android:layout_marginHorizontal="30dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/rv1wfzsbdzji"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="7dp"
                    android:src="@drawable/boxicons_ruble"
                    app:tint="@color/color_text"
                    app:tintMode="src_atop"
                    android:scaleType="fitXY" />

                <LinearLayout
                    android:id="@+id/r89iaxbywlv7"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rof25ue9wr3h"
                        android:textColor="@color/color_text"
                        android:textSize="20sp"
                        android:layout_marginBottom="8dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="1 000 000,00" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ro9gvy4m6rw"
                            android:layout_width="47dp"
                            android:layout_height="47dp"
                            android:src="@drawable/card_pepe"
                            android:scaleType="fitXY" />

                        <TextView
                            android:id="@+id/rgiks793ggs6"
                            android:textColor="@color/color_text"
                            android:textSize="20sp"
                            android:layout_marginStart="10dp"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="4205" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>