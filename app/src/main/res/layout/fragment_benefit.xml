<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fon"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="#1C029B"
            android:paddingVertical="10dp"
            android:layout_marginBottom="78dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/titleBenefits"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="34dp"
                android:layout_height="wrap_content"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Выгоды" />

            <ImageView
                android:id="@+id/benefitImage"
                android:layout_width="0dp"
                android:layout_height="204dp"
                android:layout_weight="1"
                android:src="@drawable/benefit_pepe"
                android:scaleType="fitXY" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/benefitsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="39dp"
            android:layout_marginHorizontal="20dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/blockPromotions"
                android:layout_width="0dp"
                android:layout_height="102dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:background="@drawable/button_fon"
                android:orientation="vertical"
                android:padding="10dp">

                <ImageView
                    android:id="@+id/imgStar1"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginBottom="3dp"
                    android:src="@drawable/ph_percent"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/tvPromotions"
                    android:textColor="@color/color_text"
                    android:textSize="24sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Акции" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/blockCredit"
                android:layout_width="0dp"
                android:layout_height="102dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/button_fon"
                android:orientation="vertical"
                android:padding="10dp">

                <ImageView
                    android:id="@+id/imgStar2"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginBottom="3dp"
                    android:src="@drawable/boxicons_ruble"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/tvCredit"
                    android:textColor="@color/color_text"
                    android:textSize="24sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Кредит" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/partnersBlock"
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:gravity="center"
            android:background="@drawable/button_fon"
            android:layout_marginBottom="120dp"
            android:layout_marginHorizontal="20dp"
            android:clickable="true"
            android:focusable="true"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/starIcon"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginEnd="15dp"
                android:src="@drawable/mdi_partnership"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/partnersText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text"
                android:textSize="24sp"
                android:text="Партнеры" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>