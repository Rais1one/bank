                    android:layout_width="0dp"
                    android:layout_height="204dp"
                    android:layout_weight="1"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitXY"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rauf6arfoy4h"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="39dp"
                android:layout_marginHorizontal="20dp"
                android:orientation="horizontal">


                <LinearLayout
                    android:id="@+id/block_promotions"
                    android:layout_width="0dp"
                    android:layout_height="102dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/cr15b939393"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <ImageView
                        android:id="@+id/img_star_1"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:layout_marginBottom="3dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY" />
                    <TextView
                        android:id="@+id/tv_promotions"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Акции" />
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/block_credit"
                    android:layout_width="0dp"
                    android:layout_height="102dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/cr15b939393"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <ImageView
                        android:id="@+id/img_star_2"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:layout_marginBottom="3dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY" />
                    <TextView
                        android:id="@+id/tv_credit"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Кредит" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rdiy0kna4vwb"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:gravity="center"
                android:background="@drawable/cr15b939393"
                android:layout_marginBottom="120dp"
                android:layout_marginHorizontal="20dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal"> <!-- Горизонтально, чтобы звезда была слева -->

                <ImageView
                    android:id="@+id/star_icon"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginEnd="15dp"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/rh0q0tuo475"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:text="Партнеры" />

            </LinearLayout>



            тут

            <LinearLayout
                android:id="@+id/ry3p14qii9pm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
