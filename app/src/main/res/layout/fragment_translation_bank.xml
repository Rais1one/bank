<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fon"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/banktotrans"
            android:layout_width="61dp"
            android:layout_height="61dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/circle"
            android:layout_marginBottom="15dp"
            >
            <ImageView
                android:id="@+id/rkexvg38vef"
                android:layout_width="61dp"
                android:layout_height="61dp"
                android:src="@drawable/ic_back"
                android:scaleType="fitXY"

                />
        </LinearLayout>
        <TextView
            android:text="1 000 000,00 ₽"
            android:id="@+id/rlikb0p2otsp"
            android:textColor="@color/color_text"
            android:textSize="32sp"
            android:layout_marginBottom="74dp"
            android:layout_marginHorizontal="29dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_fon"
            android:paddingVertical="36dp"
            android:paddingHorizontal="15dp"
            />

        <LinearLayout
            android:id="@+id/rsjka8dwj9im"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginHorizontal="29dp"
            android:layout_marginBottom="80dp"
            android:background="@drawable/button_fon"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingVertical="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="0dp"
                android:layout_marginBottom="25dp"
                android:animateLayoutChanges="true"
                android:orientation="vertical">


                <LinearLayout
                    android:id="@+id/layout_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/text_fon"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="19dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Выберите банк"
                        android:textColor="@color/color_text"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="#000000" />
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/layout_expandable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:orientation="vertical"
                    android:background="@drawable/text_fon"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="**** 4205"
                        android:textColor="#000000"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="**** 8832"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <EditText
                android:id="@+id/rogc5vsb2ew"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/text_fon"
                android:hint="Сумма от 0,01 до 30 000 000"
                android:inputType="text"
                android:paddingHorizontal="17dp"
                android:paddingVertical="18dp"
                android:textColor="@color/color_text"
                android:textSize="16sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/rixaw3v27clj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:background="@drawable/cr15b247625"
            android:paddingVertical="19dp"
            android:layout_marginHorizontal="31dp"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">
            <TextView
                android:id="@+id/rrgyj1syx48o"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Отправить"
                />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
