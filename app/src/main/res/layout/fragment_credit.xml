<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fon"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/cretoben"
            android:layout_width="61dp"
            android:layout_height="61dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/circle"
            android:layout_marginBottom="15dp"
            >
            <ImageView
                android:id="@+id/rkexvg38vef"
                android:layout_width="61dp"
                android:layout_height="61dp"
                android:src="@drawable/ic_back"
                android:scaleType="fitXY"

                />
        </LinearLayout>

        <TextView
            android:id="@+id/r69h7w2imnyl"
            android:textColor="@color/color_text"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="43dp"
            android:layout_marginStart="31dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Кредит"
            />
        <TextView
            android:id="@+id/rlikb0p2otsp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="29dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/button_fon"
            android:text="за месяц \n0,00 ₽"
            android:inputType="numberDecimal"
            android:paddingHorizontal="15dp"
            android:paddingVertical="30dp"
            android:textColor="@color/color_text"
            android:textSize="24sp" />


        <LinearLayout
            android:id="@+id/rsjka8dwj9im"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="29dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/button_fon"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingVertical="32dp">

            <EditText
                android:id="@+id/r9xyz0n95dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="25dp"
                android:background="@drawable/text_fon"
                android:hint="Сумма"
                android:inputType="text"
                android:paddingHorizontal="17dp"
                android:paddingVertical="19dp"
                android:textColor="@color/color_text"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="0dp"
                android:layout_marginBottom="25dp"
                android:animateLayoutChanges="true"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/text_fon"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="19dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Процент"
                        android:textColor="@color/color_text"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="#000000" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_expandable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/text_fon"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="9%"
                        android:textColor="#000000"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="12%"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>


            <EditText
                android:id="@+id/r9xyz0n95dcp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:background="@drawable/text_fon"
                android:hint="Период"
                android:inputType="text"
                android:paddingHorizontal="17dp"
                android:paddingVertical="19dp"
                android:textColor="@color/color_text"
                android:textSize="16sp" />


        </LinearLayout>

        <LinearLayout
            android:id="@+id/rixaw3v27clj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:background="@drawable/cr15b247625"
            android:paddingVertical="19dp"
            android:layout_marginHorizontal="31dp"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical">
            <TextView
                android:id="@+id/rrgyj1syx48o"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Оформить"
                />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
