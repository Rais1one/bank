<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:orientation="vertical"
        >
        <ImageView
            android:id="@+id/rk1yczkvzz2a"
            android:layout_width="61dp"
            android:layout_height="61dp"
            android:layout_marginBottom="30dp"
            android:layout_marginStart="13dp"
            android:layout_marginTop="10dp"
            android:src="@android:drawable/star_big_on"
            android:scaleType="fitXY"
            />

        <ImageView
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center"/>

       <TextView
           android:layout_width="143dp"
           android:layout_height="24dp"
           android:layout_gravity="center"
           android:text="Продукты"
           android:gravity="center"
           android:textSize="20sp"/>
        <TextView
            android:layout_width="143dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:text="14 марта 14:06"
            android:gravity="center"
            android:textSize="14sp"/>
        <TextView
            android:layout_width="143dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:text="-276,50"
            android:gravity="center"
            android:textSize="20sp"/>
    </LinearLayout>
    <RelativeLayout
        android:layout_width="366dp"
        android:layout_height="83dp"
        android:layout_gravity="center"
        android:padding="12dp"
        android:background="@drawable/cr10bd9d9d9">

        <!-- КАРТИНКА (слева по центру) -->
        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_gallery" />

        <!-- ТЕКСТ СВЕРХУ (Покупка по карте) -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iv_icon"
            android:layout_marginStart="16dp"
            android:layout_alignTop="@id/iv_icon"
            android:text="Покупка по карте"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- ТЕКСТ СНИЗУ (Цифры 4205) -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iv_icon"
            android:layout_below="@id/tv_title"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="4205"
            android:textColor="#808080"
            android:textSize="14sp" />

    </RelativeLayout>

    </LinearLayout>




