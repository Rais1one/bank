<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fon"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/destopro"
            android:layout_width="61dp"
            android:layout_height="61dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/circle"
            android:layout_marginBottom="15dp"
            >
            <ImageView
                android:id="@+id/rkexvg38vef"
                android:layout_width="61dp"
                android:layout_height="61dp"
                android:src="@drawable/ic_back"
                android:scaleType="fitXY"

                />
        </LinearLayout>

        <TextView
            android:id="@+id/r69h7w2imnyl"
            android:textColor="@color/color_text"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="30dp"
            android:layout_marginStart="31dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Описание"
            />
        
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="15dp"
            android:src="@drawable/pepe_good"
            android:layout_gravity="center"/>

        <LinearLayout
            android:layout_width="350dp"
            android:layout_height="400dp"
            android:layout_gravity="center"
            android:background="@drawable/button_fon">

            <TextView
                android:id="@+id/tv_about_bank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/color_text"
                android:textSize="16sp"
                android:text="PEPE БАНК — это современный цифровой банк, созданный для быстрых и удобных финансовых операций. Мы объединяем технологии и простой интерфейс, чтобы управление деньгами было понятным и доступным каждому.\n\nНаши возможности:\n— Мгновенные переводы\n— Кэшбэк\n— Контроль финансов\n\nМы не просто банк. Мы — место, где деньги живут своей жизнью.\nPEPE БАНК — шнеле. просто. ватафа." />

        </LinearLayout>



    </LinearLayout>
        
    </LinearLayout>


