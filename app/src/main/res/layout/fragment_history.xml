<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/fon"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="#1C029B"
            android:paddingVertical="13dp"
            android:layout_marginBottom="30dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/titleHistory"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:layout_marginStart="26dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="История" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/historyImage"
                android:layout_width="133dp"
                android:layout_height="133dp"
                android:layout_marginEnd="9dp"
                android:src="@drawable/pepe_money"
                android:scaleType="fitXY" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/statsContainer"
            android:layout_width="match_parent"
            android:layout_height="138dp"
            android:layout_marginHorizontal="23dp"
            android:layout_marginBottom="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/outcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_fon"
                android:orientation="vertical"
                android:paddingStart="21dp"
                android:paddingTop="17dp"
                android:paddingEnd="90dp">

                <TextView
                    android:id="@+id/priceOutcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="19dp"
                    android:text="2 009"
                    android:textColor="@color/color_text"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/textOutcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-1dp"
                    android:layout_marginBottom="30dp"
                    android:text="Траты"
                    android:textColor="@color/color_text"
                    android:textSize="15sp" />

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/income"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_fon"
                android:orientation="vertical"
                android:paddingStart="21dp"
                android:paddingTop="17dp"
                android:paddingEnd="90dp">

                <TextView
                    android:id="@+id/priceIncome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="19dp"
                    android:text="5 000"
                    android:textColor="@color/color_text"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/textIncome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="30dp"
                    android:text="Доходы"
                    android:textColor="@color/color_text"
                    android:textSize="15sp" />

            </LinearLayout>

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="250dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/todayLabel"
                    android:textColor="@color/color_text"
                    android:textSize="20sp"
                    android:layout_marginBottom="11dp"
                    android:layout_marginStart="24dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Сегодня" />

                <LinearLayout
                    android:id="@+id/itemProducts1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="@drawable/button_fon"
                    android:paddingVertical="20dp"
                    android:layout_marginBottom="13dp"
                    android:layout_marginHorizontal="23dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/products1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="17dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/tdesign_shop"
                        android:scaleType="fitXY" />

                    <TextView
                        android:id="@+id/productsText1"
                        android:textColor="@color/color_text"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Продукты" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/amount1"
                        android:textColor="@color/color_text"
                        android:textSize="15sp"
                        android:layout_marginEnd="31dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="-276,50" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemTransfer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="@drawable/button_fon"
                    android:paddingVertical="18dp"
                    android:layout_marginBottom="29dp"
                    android:layout_marginHorizontal="23dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/transfer"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="17dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/si_money"
                        android:scaleType="fitXY" />

                    <TextView
                        android:id="@+id/transferText"
                        android:textColor="@color/color_text"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Перевод" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/transferAmount"
                        android:textColor="@color/color_text"
                        android:textSize="15sp"
                        android:layout_marginEnd="28dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="5 000,00" />

                </LinearLayout>

                <TextView
                    android:id="@+id/dateLabel"
                    android:textColor="@color/color_text"
                    android:textSize="20sp"
                    android:layout_marginBottom="14dp"
                    android:layout_marginStart="32dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="13 марта" />

                <LinearLayout
                    android:id="@+id/itemRestaurant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="@drawable/button_fon"
                    android:paddingVertical="18dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginHorizontal="23dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/restaurant"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="17dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_restaurant"
                        android:scaleType="fitXY" />

                    <TextView
                        android:id="@+id/restaurantText"
                        android:textColor="@color/color_text"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Ресторан" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/restaurantAmount"
                        android:textColor="@color/color_text"
                        android:textSize="15sp"
                        android:layout_marginEnd="30dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="-1 276,50" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemProducts2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:background="@drawable/button_fon"
                    android:paddingVertical="13dp"
                    android:layout_marginHorizontal="23dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/products2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="17dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/tdesign_shop"
                        android:scaleType="fitXY" />

                    <TextView
                        android:id="@+id/productsText2"
                        android:textColor="@color/color_text"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Продукты" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/amount2"
                        android:textColor="@color/color_text"
                        android:textSize="15sp"
                        android:layout_marginEnd="30dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="-456,76" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</LinearLayout>