<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">


        <LinearLayout
            android:id="@+id/rmcks10r9e68"
            android:layout_width="61dp"
            android:layout_height="61dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="13dp"
            android:background="@drawable/circle"
            >
            <ImageView
                android:id="@+id/rkexvg38vef"
                android:layout_width="61dp"
                android:layout_height="61dp"
                android:src="@android:drawable/star_big_on"
                android:scaleType="fitXY"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rnr3m9q79eo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_marginBottom="5dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/rclqtx86bqgc"
                android:textColor="#000000"
                android:textSize="48sp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="5 000 ₽"
                />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/rmcks10r9e68"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_marginBottom="7dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/r0xjhqr8mdw1n"
                android:textColor="#000000"
                android:textSize="24sp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Доходы"
                />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="400dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/ricuh1g6aaee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="27dp"
                    android:layout_marginBottom="11dp"
                    android:text="Сегодня"
                    android:textColor="#000000"
                    android:textSize="20sp" />
                <!-- Блок Продукты (Сегодня) -->
                <LinearLayout
                    android:id="@+id/rrf6f2p374ho"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="26dp"
                    android:layout_marginBottom="27dp"
                    android:background="@drawable/cr10bd9d9d9"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="11dp"
                        android:scaleType="fitXY"
                        android:src="@android:drawable/star_big_on" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Переводы"
                        android:textColor="#000000"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 000,00
                         ₽"
                        android:textColor="#000000"
                        android:textSize="15sp" />
                </LinearLayout>



            </LinearLayout>
        </ScrollView>

    </LinearLayout>