<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fon"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/stotoben"
                android:layout_width="61dp"
                android:layout_height="61dp"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="15dp"
                android:background="@drawable/circle"
                android:layout_marginBottom="15dp"
                >
                <ImageView
                    android:id="@+id/rkexvg38vef"
                    android:layout_width="61dp"
                    android:layout_height="61dp"
                    android:src="@drawable/ic_back"
                    android:scaleType="fitXY"

                    />
            </LinearLayout>
            <TextView
                android:id="@+id/r69h7w2imnyl"
                android:textColor="@color/color_text"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="53dp"
                android:layout_marginStart="31dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Акции"
                />
            <RelativeLayout
                android:layout_width="349dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/button_fon">

                <ImageView
                    android:id="@+id/img_gif1t"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/people" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/img_gif1t"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:text="Пригласи друга и вы получите каждый по 500 руб"
                    android:textColor="@color/color_text"
                    android:textSize="15sp" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="349dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/button_fon">

                <ImageView
                    android:id="@+id/img_gift3"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/proc" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/img_gift3"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:text="Получи 100% кэшбэка за покупку напитка Coca-Cola"
                    android:textColor="@color/color_text"
                    android:textSize="15sp" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="349dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/button_fon">

                <ImageView
                    android:id="@+id/img_gift4"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/give_money" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/img_gift4"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:text="Открой накопительный счет под 18% годовых"
                    android:textColor="@color/color_text"
                    android:textSize="15sp" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="349dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_fon">

                <ImageView
                    android:id="@+id/img_gift"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/money" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/img_gift"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:text="Открой инвесткопилку и получайте прибыль каждый день"
                    android:textColor="@color/color_text"
                    android:textSize="15sp" />
            </RelativeLayout>

        </LinearLayout>

</LinearLayout>
