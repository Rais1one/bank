<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/rnk82jmoei"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:paddingTop="20dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/rwq3n4xaw7rr"
                android:layout_width="61dp"
                android:layout_height="61dp"
                android:layout_marginBottom="54dp"
                android:layout_marginStart="14dp"
                android:src="@android:drawable/star_big_on"
                android:scaleType="fitXY"
                />
            <TextView
                android:id="@+id/r69h7w2imnyl"
                android:textColor="#000000"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="53dp"
                android:layout_marginStart="31dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Акции"
                />
            <RelativeLayout
                android:layout_width="349dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/cr15bd9d9d9">

                <ImageView
                    android:id="@+id/img_gift"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_share" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/img_gift"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:text="Пригласи друга и вы получите каждый по 500 руб"
                    android:textColor="#000000"
                    android:textSize="15sp" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="349dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/cr15bd9d9d9">

                <ImageView
                    android:id="@+id/img_gift"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_share" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/img_gift"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:text="Получи 100% кэшбэка за покупку напитка Coca-Cola"
                    android:textColor="#000000"
                    android:textSize="15sp" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="349dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/cr15bd9d9d9">

                <ImageView
                    android:id="@+id/img_gift"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_share" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/img_gift"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:text="Открой накопительный счет под 18% годовых"
                    android:textColor="#000000"
                    android:textSize="15sp" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="349dp"
                android:layout_height="75dp"
                android:layout_gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/cr15bd9d9d9">

                <ImageView
                    android:id="@+id/img_gift"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_share" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/img_gift"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:text="Открой инвесткопилку и получайте прибыль каждый день"
                    android:textColor="#000000"
                    android:textSize="15sp" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
