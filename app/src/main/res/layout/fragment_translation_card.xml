<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/rk1yczkvzz2a"
                android:layout_width="61dp"
                android:layout_height="61dp"
                android:layout_marginBottom="41dp"
                android:layout_marginStart="13dp"
                android:layout_marginTop="10dp"
                android:src="@android:drawable/star_big_on"
                android:scaleType="fitXY"
                />
            <EditText
                android:inputType="text"
                android:hint="1 000 000,00 ₽"
                android:id="@+id/rlikb0p2otsp"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:layout_marginBottom="74dp"
                android:layout_marginHorizontal="29dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/cr15b757575"
                android:paddingVertical="36dp"
                android:paddingHorizontal="15dp"
                />

            <LinearLayout
                android:id="@+id/rsjka8dwj9im"
                android:layout_width="match_parent"
                android:layout_height="224dp"
                android:layout_marginHorizontal="29dp"
                android:layout_marginBottom="80dp"
                android:background="@drawable/cr15bd9d9d9"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingVertical="32dp">

                <EditText
                    android:id="@+id/r9xyz0n95dcp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="25dp"
                    android:background="@drawable/cr10bfffafa"
                    android:hint="Номер карты"
                    android:inputType="text"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="19dp"
                    android:textColor="#000000"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/rogc5vsb2ew"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/cr10bfffafa"
                    android:hint="Сумма от 0,01 до 30 000 000"
                    android:inputType="text"
                    android:paddingHorizontal="17dp"
                    android:paddingVertical="18dp"
                    android:textColor="#000000"
                    android:textSize="16sp" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rixaw3v27clj"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:background="@drawable/cr15b247625"
                android:paddingVertical="19dp"
                android:layout_marginHorizontal="31dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/rrgyj1syx48o"
                    android:textColor="#000000"
                    android:textSize="32sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Отправить"
                    />
            </LinearLayout>
        </LinearLayout>

</LinearLayout>
