<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/rk1yczkvzz2a"
            android:layout_width="61dp"
            android:layout_height="61dp"
            android:layout_marginBottom="30dp"
            android:layout_marginStart="13dp"
            android:layout_marginTop="10dp"
            android:src="@android:drawable/star_big_on"
            android:scaleType="fitXY"
            />

        <ImageView
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center"/>

        <LinearLayout
            android:layout_width="170dp"
            android:layout_height="48dp"
            android:background="@drawable/photo"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:text="Изменить фото"
                android:gravity="center"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/rsjka8dwj9im"
            android:layout_width="match_parent"
            android:layout_height="374dp"
            android:layout_marginHorizontal="29dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/cr15bd9d9d9"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingVertical="32dp">

            <TextView
                android:id="@+id/r9xyz0n95dcp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="25dp"
                android:background="@drawable/cr10bfffafa"
                android:hint="Имя"
                android:inputType="text"
                android:paddingHorizontal="17dp"
                android:paddingVertical="19dp"
                android:textColor="#000000"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/rogc5vsb2ew"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/cr10bfffafa"
                android:hint="Фамилия"
                android:paddingHorizontal="17dp"
                android:paddingVertical="18dp"
                android:textColor="#000000"
                android:layout_marginBottom="25dp"
                android:textSize="16sp" />


            <TextView
                android:id="@+id/rogc5vsb2ew"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/cr10bfffafa"
                android:hint="+7-(921)-574-43-85"
                android:inputType="text"
                android:paddingHorizontal="17dp"
                android:paddingVertical="18dp"
                android:textColor="#000000"
                android:layout_marginBottom="25dp"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/r9xyz0n95dcp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/cr10bfffafa"
                android:hint="12.01.2000"
                android:inputType="text"
                android:paddingHorizontal="17dp"
                android:paddingVertical="19dp"
                android:textColor="#000000"
                android:textSize="16sp" />


        </LinearLayout>


    </LinearLayout>

</LinearLayout>


